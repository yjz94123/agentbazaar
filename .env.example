# ==================== App ====================
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ==================== LLM (Optional - falls back to mock) ====================
# DeepSeek (recommended for cost)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
MODEL_NAME=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1

# OpenAI (alternative)
# OPENAI_API_KEY=your_openai_api_key_here
# MODEL_NAME=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1

# ==================== x402 Payment ====================
X402_ENABLED=true
X402_CHAIN=GOAT Testnet3
X402_TOKEN=USDC
X402_RECEIVER=0xYourPlatformWalletAddress

# ==================== ERC-8004 (Optional) ====================
ERC8004_RPC_URL=https://your-goat-testnet3-rpc
ERC8004_PRIVATE_KEY=0xYourPrivateKey
ERC8004_REGISTRY_ADDRESS=0xRegistryContractAddress

# ==================== Frontend ====================
NEXT_PUBLIC_API_URL=http://localhost:3001
